# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# --- Appointment data ---
FECHA_NACIMIENTO=DD/MM/YYYY        # Date of birth (e.g. 18/10/1985)
PAIS=                              # Country of your foreign licence (e.g. Alemania)
LOCALIZADOR=                       # DGT application reference number (8-char code)
CONFIRMATION_CODE=                 # Confirmation / expediente code from DGT

# --- Office ---
CENTRO=                            # DGT office city (e.g. Barcelona)

# --- Schedule ---
CHECK_INTERVAL_MINUTES=10          # How often to poll (minutes)
START_HOUR=8                       # Bot active from this hour (0-23, CET)
END_HOUR=22                        # Bot active until this hour (0-23, CET)
